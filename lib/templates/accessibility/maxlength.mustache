{{!
    @template core/accessibility/maxlength

    This template is used to announce the character count of text inputs
    and textareas when the user types in them.

    Classes required for JS:
    * core/accessibility/maxlength_announcer

    Context variables required for this template:
    * none

    Example context (json):
    {
    }
}}
<div data-announcerid="maxlength_announcer_0" aria-live="polite" aria-atomic="true" class="visually-hidden"></div>
{{#js}}
require(['core/accessibility/maxlength_announcer'], function(maxlength_announcer) {
    maxlength_announcer.init();
});
{{/js}}
